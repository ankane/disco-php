{
    "name": "ankane/disco",
    "description": "Recommendations for PHP using collaborative filtering",
    "license": "MIT",
    "support": {
        "issues": "https://github.com/ankane/disco-php/issues",
        "source": "https://github.com/ankane/disco-php"
    },
    "authors": [
        {
            "name": "Andrew Kane",
            "email": "andrew@ankane.org"
        }
    ],
    "autoload": {
        "psr-4": {
            "Disco\\": "src/"
        }
    },
    "require": {
        "php": ">= 8.2",
        "ankane/libmf": "^0.3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "scripts": {
        "test": "phpunit tests",
        "valgrind": "valgrind --leak-check=full --trace-children=yes --error-exitcode=1 --quiet phpunit tests",
        "post-install-cmd": "Disco\\Library::check",
        "post-update-cmd": "Disco\\Library::check"
    }
}
